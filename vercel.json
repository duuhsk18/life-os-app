{
  "rewrites": [
    {
      "source": "/((?!api/|entregaveis/|assets/|.*\\.(?:js|css|png|jpg|jpeg|svg|webp|gif|ico|json|html|txt|woff|woff2|ttf|eot|map|mp4|webm|mov|m4v|mp3|wav|pdf)$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/entregaveis/(.*)/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/entregaveis/(.*)/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-kiwify-sync",
      "schedule": "0 6 * * *"
    }
  ]
}
